{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
              "Runtime/**/*.cs",
              "Editor/**/*.cs"
          ]
        }
      ],
      "dest": "Documentation~/api",
      "allowCompilationErrors": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "Documentation~/_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "Documentation~/_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "DialogueSystem",
      "_appTitle": "DialogueSystem",
      "_enableSearch": true,
      "pdf": true
    }
  }
}